{
  "name": "electricsheep",
  "version": "0.1.0",
  "description": "A local-first bookmarker for AI conversations, clipboard snippets, notes, and screenshots.",
  "main": "src/main.js",
  "build": {
    "appId": "local.electricsheep.app",
    "productName": "Electric Sheep",
    "asar": false,
    "npmRebuild": false,
    "afterPack": "scripts/after-pack.js",
    "files": [
      "index.html",
      "image.png",
      "bin/**/*",
      "src/**/*",
      "scripts/ax-read.swift",
      "scripts/capture-window.swift",
      "scripts/ocr.swift",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "identity": null,
      "target": [
        "dir",
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "zip"
      ]
    },
    "directories": {
      "output": "release"
    }
  },
  "bin": {
    "sheep": "bin/sheep.js"
  },
  "scripts": {
    "start": "electron .",
    "sheep": "node bin/sheep.js",
    "lamb": "node scripts/lamb-server.js",
    "lamb:track": "node bin/sheep.js track",
    "test": "node scripts/smoke-test.js",
    "open": "npm start",
    "open:app": "open \"release/mac-arm64/Electric Sheep.app\"",
    "pack": "electron-builder --dir",
    "pack:win": "electron-builder --win --x64 --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --x64",
    "dist:lamb": "node scripts/package-lamb.js",
    "dist:lamb:all": "npm run dist:lamb && npm run dist:lamb:app && npm run dist:lamb:app:standalone && npm run dist:lamb:manifest",
    "dist:lamb:app": "node scripts/package-lamb-app.js",
    "dist:lamb:app:thin": "node scripts/package-lamb-app.js",
    "dist:lamb:app:standalone": "node scripts/package-lamb-app.js --standalone",
    "dist:lamb:manifest": "node scripts/write-lamb-release-manifest.js",
    "verify:lamb:release": "node scripts/verify-lamb-release.js",
    "check:lamb:size": "node scripts/check-lamb-size-budget.js",
    "release:lamb": "npm run dist:lamb:all && npm run verify:lamb:release && npm run check:lamb:size && npm run smoke:lamb && npm run preflight:lamb:trusted",
    "preflight:lamb": "npm run preflight:lamb:trusted",
    "preflight:lamb:trusted": "node scripts/preflight-lamb-release.js --trusted",
    "preflight:lamb:public": "node scripts/preflight-lamb-release.js --public",
    "notarize:lamb": "node scripts/notarize-lamb-app.js",
    "smoke:lamb:app": "node scripts/smoke-lamb-app.js",
    "smoke:lamb:server": "node scripts/smoke-lamb-server.js",
    "smoke:lamb:ui": "node scripts/smoke-lamb-ui.js",
    "smoke:lamb": "npm run smoke:lamb:server && npm run smoke:lamb:ui && npm run smoke:lamb:app",
    "dist:lite": "node scripts/package-lamb.js"
  },
  "keywords": [
    "ai",
    "bookmarks",
    "clipboard",
    "screenshots",
    "notes"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "playwright-core": "^1.60.0"
  },
  "dependencies": {
    "node-pty": "^1.1.0"
  }
}
